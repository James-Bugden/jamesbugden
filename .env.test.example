# Copy to .env.test and fill in. .env.test is gitignored.
QA_TEST_EMAIL=test@test.com
QA_TEST_PASSWORD=changeme
# Override to http://localhost:5173 when running locally with `npm run dev`.
# Default hits the live site.
QA_BASE_URL=https://jamesbugden.com
# Production smoke probe target (production-smoke-scheduled workflow).
# Override to a staging origin to dry-run the probe locally.
PROD_BASE=https://jamesbugden.com
